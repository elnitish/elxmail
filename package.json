  "repository": {
    "type": "git",
    "url": "git+https://github.com/elnitish/elxmail.git"
  },
  "bugs": {
    "url": "https://github.com/elnitish/elxmail/issues"
  },
  "homepage": "https://github.com/elnitish/elxmail#readme",
